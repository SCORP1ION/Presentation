---
import style from "../../styles/components/cardprojects.module.css";

const projects = [
  {
    image: "/img/LMservice.jpeg",
    title: "Laptop master service",
    description:
      "Aplicacion movil de asginaciona de servicios sobre problemas de equipos para empresas o negocios, apartado de venta de equipos de computo y ubicacion de local con google maps",
    technologies: ["React native", "Firebase", "JavaScript"],
    code: "https://github.com/SCORP1ION/Laptop-Master-Service.git",
  },
  {
    image: "/img/PageDeepTeal.png",
    title: "Deep Teal",
    description: "Landing page creada para practica una landing page económica, rápida de implementar y enfocada en generación de leads / contacto, con una sola acción principal.",
    technologies: ["Astro", "HTML", "CSS"],
    code: "https://github.com/SCORP1ION/landing-DeepTealSolutions.git"
  },
  {
    image: "/img/laPaloma.png",
    title: "La Paloma",
    description: "Pagina web de cotizaciones de palomitas y otros productos por mayoreo con numero",
    technologies: ["Astro", "HTML", "CSS"],
    code: "https://github.com/SCORP1ION/LandingPageLaPaloma.git"
  },
  
];
---

<section class={style.projectGrid}>
  {
    projects.map((project) => (
      <article class={style.card}>
        <img src={project.image} alt={project.title} />

        <div class={style.content}>
          <h3 class={style.titulo}>{project.title}</h3>
          <p class={style.description}>{project.description}</p>

          <div class={style.tech}>
            {project.technologies.map((tech) => (
              <span>{tech}</span>
            ))}
          </div>

          <a
            href={project.code}
            class={style.button}
            target="_blank"
            rel="noopener noreferrer"
          >
            View code
          </a>
        </div>
      </article>
    ))
  }
</section>
