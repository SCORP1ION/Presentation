---
import style from "../../styles/components/tecnologies.module.css";

const skill = [
  "JavaScript",
  "C++",
  "Astro",
  "HTML5",
  "Flutter",
  "React Navite",
  "React",
  "CSS",
];
---
 
<section id="skill">
  <div class={style.skill}>
    <h1>SKILLS</h1>
  </div>
  <div class={style.lenguajes}>
    {skill.map((skills) => <a>{skills}</a>)}
  </div>
</section>
