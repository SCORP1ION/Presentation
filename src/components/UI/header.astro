---
import styles from "../../styles/UI/header.module.css";
import BottomText from "./BottomText.astro";
---

<header class={styles.encabezado}>
    <div class={styles.left}>
        <h1>RIGR</h1>
    </div>
 
    <div class={styles.navigationContainer}>
        <nav class={styles.navigation}>
            <a href="#about">ABOUT</a>
            <a href="#projects">PROJECTS</a>
            <a href="#skill">SKILL</a>
            <a href="#experience">EXPERIENCE</a>
            <a href="#contact">CONTACT</a>
        </nav>
    </div>

    <div class={styles.right}>
        <div class={styles.cvWrapper}><BottomText text="Download CV"/></div>
        
        <button
            class={styles.burger}
            aria-label="Open menu"
            aria-controls="mobile-menu"
            aria-expanded="false"
            data-burger
        >☰
        </button>
    </div>

    <div class={styles.backdrop} data-backdrop></div>

    <aside class={styles.mobileMenu} data-menu id="mobile-menu" aria-hidden="true">
        <div class={styles.mobileHeader}>
            <p class={styles.mobileTitle}>Menu</p>
            <button class={styles.close} type="button" aria-label="Cerrar menu" data-close>X</button>
        </div>

        <div class={styles.mobileNav} aria-label="Navegacion movil">
            <a data-link>ABOUT</a>
            <a data-link>PROJECTS</a>
            <a data-link>SKILL</a>
            <a data-link>EXPERIENCE</a>
            <a data-link>CONTACT</a>
        </div>
        <BottomText text="Download CV" />
    </aside>
</header>

<script is:inline>
    const burger = document.querySelector("[data-burger]");
    const menu = document.querySelector("[data-menu]");
    const backdrop = document.querySelector("[data-backdrop]");
    const closeBtn = document.querySelector("[data-close]");
    const links = document.querySelectorAll("[data-link]");

    const openMenu = () => {
        document.body.dataset.menuOpen = "true";
        burger?.setAttribute("aria-expanded", "true");
        menu?.setAttribute("aria-hidden", "false");
    };

    const closeMenu = () => {
        document.body.dataset.menuOpen = "false";
        burger?.setAttribute("aria-expanded", "false")
        menu?.setAttribute("aria-hidden", "true")
    };

    burger?.addEventListener("click", () => {
        const isOpen = document.body.dataset.menuOpen === "true";
        isOpen ? closeMenu() : openMenu();
    });

    closeBtn?.addEventListener("click", closeMenu);
    backdrop?.addEventListener("click", closeMenu);

    links.forEach((link) => link.addEventListener("click", closeMenu)); 

    document.body.dataset.menuOpen = "false";
</script>
